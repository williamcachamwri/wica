# wica — environment variables
#
# This project runs on Cloudflare Pages. Most secrets below are consumed by
# Cloudflare Pages Functions (see /functions/api) and should be uploaded with:
#
#   npx wrangler pages secret put <NAME> --project-name=wica
#
# Local development only needs the values you are actively testing.

# ── Spotify (Now Playing widget) ──────────────────────────────────────
# Required for /api/now-playing
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# ── GitHub ────────────────────────────────────────────────────────────
# Required for GitHub Activity, changelog, guestbook, and blog comments/likes.
# Token needs: repo, read:user, read:discussion
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub OAuth for blog comments and likes.
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=Iv1.xxxxxxxx
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ── Cloudflare Analytics (Insights chart) ─────────────────────────────
# Required for /api/insights
# Token needs: Zone:Read, Zone Analytics:Read
# Zone ID is in the right sidebar of your domain overview in Cloudflare Dashboard.
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# ── Turnstile (Guestbook spam protection) ─────────────────────────────
# Required for /api/guestbook
# Get a site key + secret at: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=1x0000000000000000000000000000AA
